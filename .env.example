# Copy this file to .env and fill in your values.
# Hugo reads HUGO_PARAMS_* variables and merges them into .Site.Params.*
# .env is gitignored — never commit it.

# Firebase project config (client-side safe — not secrets)
# Project: collection-showcase-auth
HUGO_PARAMS_FIREBASE_API_KEY=
HUGO_PARAMS_FIREBASE_AUTH_DOMAIN=collection-showcase-auth.firebaseapp.com
HUGO_PARAMS_FIREBASE_PROJECT_ID=collection-showcase-auth
HUGO_PARAMS_FIREBASE_STORAGE_BUCKET=collection-showcase-auth.firebasestorage.app
HUGO_PARAMS_FIREBASE_MESSAGING_SENDER_ID=
HUGO_PARAMS_FIREBASE_APP_ID=

# Backend API base URL
# Production: Cloud Run service 'weather-api' in us-central1, project fg-polylabs
# Local dev: http://localhost:8080
HUGO_PARAMS_BACKENDURL=http://localhost:8080

# Comma-separated list of emails allowed to sign in (mirrors backend ALLOWED_EMAILS)
HUGO_PARAMS_ALLOWED_EMAILS=you@example.com

# Static data sources
# GitHub data repo: cloud-predict-analytics-data (GitHub Raw, primary source)
HUGO_PARAMS_GITHUB_DATA_REPO=FG-PolyLabs/cloud-predict-analytics-data
# GCS fallback: 'fg-polylabs-data' bucket in GCP project fg-polylabs (managed by cloud-predict-analytics-data repo)
HUGO_PARAMS_GCS_DATA_BUCKET=fg-polylabs-weather-data
